# ████████████████████████████████████████████████████████████
# CELL 10 — PHASE B: Fine-tune (Unfreeze Top 50 Layers)
# Goal: Adapt ResNet50 feature maps to aerial/satellite imagery.
# Epochs: 20 | LR: 1e-4 | Top 50 layers unfrozen
# ████████████████████████████████████████████████████████████

PHASE_B_EPOCHS   = 20
PHASE_B_LR       = 1e-4
UNFREEZE_LAYERS  = 50       # unfreeze last 50 layers of ResNet50

# Unfreeze the top N layers
base_model.trainable = True
for layer in base_model.layers[:-UNFREEZE_LAYERS]:
