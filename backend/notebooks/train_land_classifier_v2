# CELL 11 — PHASE C: Domain Adaptation on Google Maps test_set
# Goal: Force model to learn Maps color palette.
# Uses your 500 Google Maps labeled screenshots as fine-tune data.
# Epochs: 15 | LR: 5e-5 | Heavier augmentation | Top 80 layers unfrozen
# ████████████████████████████████████████████████████████████

PHASE_C_EPOCHS   = 15
UNFREEZE_PHASE_C = 80    # start here; reduce to 60 if overfitting fast

# ── LR Warmup + Cosine Decay for Phase C ──────────────────────
# With only ~80-100 Maps images/class, starting at full LR can cause
# immediate overfitting. Warmup for 2 epochs, then cosine-decay to near zero.
PHASE_C_WARMUP_EPOCHS = 2
PHASE_C_PEAK_LR       = 5e-5
PHASE_C_MIN_LR        = 1e-7

def warmup_cosine_schedule(epoch):
    """LR warmup for first N epochs, then cosine decay."""
    import math
    if epoch < PHASE_C_WARMUP_EPOCHS:
        # Linear warmup: 10% of peak → peak LR
        return PHASE_C_MIN_LR + (PHASE_C_PEAK_LR - PHASE_C_MIN_LR) * \
               (epoch + 1) / PHASE_C_WARMUP_EPOCHS
    # Cosine decay after warmup
    progress = (epoch - PHASE_C_WARMUP_EPOCHS) / \
               max(1, PHASE_C_EPOCHS - PHASE_C_WARMUP_EPOCHS)
    return PHASE_C_MIN_LR + 0.5 * (PHASE_C_PEAK_LR - PHASE_C_MIN_LR) * \
           (1 + math.cos(math.pi * progress))

print("📈 Phase C LR schedule: warmup 2 epochs → cosine decay")
print(f"   Peak LR: {PHASE_C_PEAK_LR} | Min LR: {PHASE_C_MIN_LR}")

# ── Prepare Maps fine-tune dataset ─────────────────────────────
# Split the 500 test_set images 80/20 for fine-tune/hold-out
