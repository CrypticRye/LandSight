# Sanity check: see what the model actually predicts
# ████████████████████████████████████████████████████████████

def visualise_predictions(model, holdout_dir, class_names, n_per_class=4):
    fig, axes = plt.subplots(len(class_names), n_per_class,
                              figsize=(n_per_class * 3, len(class_names) * 3))
    fig.suptitle("Google Maps Predictions (Green=Correct, Red=Wrong)",
                 fontsize=14, fontweight="bold")

    for row, cls in enumerate(class_names):
        cls_dir = Path(holdout_dir) / cls
        files = list(cls_dir.iterdir())[:n_per_class]

        for col, f in enumerate(files):
            from PIL import Image
            img = Image.open(f).convert("RGB").resize(IMG_SIZE)
            arr = np.array(img, dtype=np.float32)
            arr_input = tf.keras.applications.resnet50.preprocess_input(arr)
            pred = model.predict(np.expand_dims(arr_input, 0), verbose=0)[0]
            pred_cls  = class_names[np.argmax(pred)]
            pred_conf = np.max(pred) * 100
            correct   = pred_cls == cls

            ax = axes[row, col]
            ax.imshow(img)
            ax.axis("off")
            color = "#2ecc71" if correct else "#e74c3c"
            ax.set_title(f"{pred_cls}\n{pred_conf:.1f}%",
                         color=color, fontsize=9, fontweight="bold")
            if col == 0:
                ax.set_ylabel(cls, fontsize=10, rotation=90, labelpad=5)

    plt.tight_layout()
    plt.savefig("/content/visual_predictions.png", dpi=150, bbox_inches="tight")
    plt.show()
    print("✅ Visual predictions saved → /content/visual_predictions.png")

