# ── Unfreeze more backbone for domain adaptation ───────────────
base_model.trainable = True
for layer in base_model.layers[:-UNFREEZE_PHASE_C]:
    layer.trainable = False

print(f"\n📊 Phase C: {UNFREEZE_PHASE_C} backbone layers unfrozen (domain adaptation)")

# Use built-in focal loss (TF 2.11+) — handles edge cases better than manual impl
try:
    focal_loss_fn = tf.keras.losses.CategoricalFocalCrossentropy(
        alpha=0.25, gamma=2.0, from_logits=False
    )
    print("✅ Using built-in CategoricalFocalCrossentropy")
except AttributeError:
    # Fallback for TF < 2.11
    print("⚠️  Built-in focal loss unavailable — using manual fallback")
    def _focal_manual(y_true, y_pred, gamma=2.0, alpha=0.25):
        eps    = tf.keras.backend.epsilon()
        y_pred = tf.clip_by_value(y_pred, eps, 1.0 - eps)
        ce     = -y_true * tf.math.log(y_pred)
        wt     = alpha * y_true * tf.pow(1 - y_pred, gamma)
        return tf.reduce_mean(tf.reduce_sum(wt * ce, axis=1))
    focal_loss_fn = _focal_manual

model.compile(
    optimizer=tf.keras.optimizers.Adam(learning_rate=PHASE_C_PEAK_LR),
    loss=focal_loss_fn,
    metrics=["accuracy"],
)

