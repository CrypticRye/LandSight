# ████████████████████████████████████████████████████████████

# Augmentation designed to bridge the SATELLITE → GOOGLE MAPS domain gap:
#   - Heavy color jitter (Maps uses vivid cartographic colors)
#   - Contrast + brightness shifts (tile rendering variation)
#   - Spatial transforms (orientation invariant aerial imagery)
#   - Simulated JPEG compression (Maps tile = JPEG artifact-prone)

def build_augmentation_model(strong=False):
    """
    Keras Sequential augmentation.
    strong=True → Phase C domain adaptation (Maps palette simulation).
    """
    layers = [
        tf.keras.layers.RandomFlip("horizontal_and_vertical"),
        tf.keras.layers.RandomRotation(0.25),
        tf.keras.layers.RandomZoom(0.15),
        tf.keras.layers.RandomTranslation(0.1, 0.1),
        tf.keras.layers.RandomBrightness(0.20),
        tf.keras.layers.RandomContrast(0.20),
    ]
    if strong:
        # Extra color transforms for Maps domain gap:
        #   Hue shift  → Maps renders water as cartographic blue
        #   Saturation → Maps uses more vivid, saturated colors than raw satellite
        layers += [
            tf.keras.layers.RandomBrightness(0.15),  # stacks → total 0.35
            tf.keras.layers.RandomContrast(0.15),
        ]
        try:
            layers += [
                tf.keras.layers.RandomHue(0.15),
                tf.keras.layers.RandomSaturation((0.6, 1.4)),
            ]
        except AttributeError:
            print("⚠️  RandomHue/RandomSaturation unavailable (TF < 2.13). Skipping.")
        # Simulate Maps tile JPEG compression artifacts (TF ≥ 2.10)
        try:
            layers.append(tf.keras.layers.RandomJpegQuality(75, 95))
        except AttributeError:
            print("⚠️  RandomJpegQuality unavailable (TF < 2.10). Skipping.")
    return tf.keras.Sequential(layers, name="augmentation")


def preprocess_resnet(image, label):
    image = tf.cast(image, tf.float32)
    image = tf.keras.applications.resnet50.preprocess_input(image)
    return image, label


def quick_eval(model, dataset, label=""):
    """Per-class F1 on any dataset — run after each phase to catch forgetting."""
    y_true, y_pred = [], []
    for images, labels in dataset:
        preds = model.predict(images, verbose=0)
        y_true.extend(np.argmax(labels.numpy(), axis=1))
        y_pred.extend(np.argmax(preds, axis=1))
    y_true, y_pred = np.array(y_true), np.array(y_pred)
    print(f"\n📊 {label}")
    print(classification_report(y_true, y_pred, target_names=CLASS_NAMES, digits=3))
    return y_true, y_pred


# ── Disk-cache directory (avoids loading everything into RAM) ─────────────
# ds.cache() with NO argument = cache to system RAM → crash on 12.7 GB Colab
# ds.cache("/content/tf_cache/...") = cache to disk (slower first epoch,
# but each subsequent epoch reads preprocessed float32 batches off SSD)
DISK_CACHE_DIR = "/content/tf_cache"
os.makedirs(DISK_CACHE_DIR, exist_ok=True)

# Cap parallel decode workers so they don't all spike RAM simultaneously.
# AUTOTUNE = unlimited threads → each thread holds a decoded batch in RAM.
# 4 workers = safe ceiling for 12.7 GB Colab free RAM.
NUM_PARALLEL = 2   # Very conservative — prevents parallel decode threads from spiking RAM


def load_dataset(directory, augment=False, strong_augment=False, shuffle=True):
    ds = tf.keras.utils.image_dataset_from_directory(
        directory,
        image_size=IMG_SIZE,
        batch_size=BATCH_SIZE,
        label_mode="categorical",
        class_names=CLASS_NAMES,
        shuffle=shuffle,
        seed=SEED,
    )
    # ── Preprocess FIRST (float32 + mean-subtraction), then optionally cache.
    # Ordering matters: cache stores the already-preprocessed tensors so the
    # conversion never repeats on subsequent epochs.
    ds = ds.map(preprocess_resnet, num_parallel_calls=NUM_PARALLEL)

    if augment:
        aug = build_augmentation_model(strong=strong_augment)
        ds = ds.map(lambda x, y: (aug(x, training=True), y),
                    num_parallel_calls=NUM_PARALLEL)

    # Disk cache ONLY for non-augmented sets (val / holdout).
    # Augmented train set must NOT be cached — augmentation must be
    # re-randomised every epoch to prevent the model memorising fixed crops.
    if not augment:
        # Build a unique, flat cache filename from the directory path
        # (avoids collisions when two datasets share the same basename)
        safe_name = directory.replace("/", "_").replace("\\", "_").strip("_")
        cache_path = os.path.join(DISK_CACHE_DIR, safe_name)
        ds = ds.cache(cache_path)

    return ds.prefetch(2)   # Low prefetch — prevents TF staging too many batches in RAM at once


