def plot_history(histories, labels, title="Training History"):
    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))
    colors = ["#3498db", "#e74c3c", "#2ecc71"]

    offset = 0
    for hist, label, color in zip(histories, labels, colors):
        epochs = range(offset + 1, offset + len(hist.history["accuracy"]) + 1)
        ax1.plot(epochs, hist.history["accuracy"],     color=color, label=f"{label} Train", linewidth=2)
        ax1.plot(epochs, hist.history["val_accuracy"], color=color, label=f"{label} Val",   linewidth=2, linestyle="--")
        ax2.plot(epochs, hist.history["loss"],         color=color, label=f"{label} Train", linewidth=2)
        ax2.plot(epochs, hist.history["val_loss"],     color=color, label=f"{label} Val",   linewidth=2, linestyle="--")
        offset += len(hist.history["accuracy"])

    for ax, metric in [(ax1, "Accuracy"), (ax2, "Loss")]:
        ax.set_xlabel("Epoch")
        ax.set_ylabel(metric)
        ax.set_title(f"{metric} — All Phases")
        ax.legend(fontsize=8)
        ax.grid(alpha=0.3)

    plt.suptitle(title, fontsize=14, fontweight="bold", y=1.02)
    plt.tight_layout()
    plt.savefig("/content/training_history.png", dpi=150, bbox_inches="tight")
    plt.show()
    print("✅ Training history saved → /content/training_history.png")

