# LandSight — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# ── Database (SQLite — no server needed, file stored in backend/) ─────────────
DATABASE_URL=sqlite:///landsight.db

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_DEBUG=true
PORT=5000
SECRET_KEY=change-me-in-production

# ── Copernicus Data Space Ecosystem (Sentinel-2) ──────────────────────────────
# Register for FREE at: https://dataspace.copernicus.eu
# After registering and verifying your email, fill in your credentials below.
COPERNICUS_USER=your_email@example.com
COPERNICUS_PASS=your_password
